        <mxCell id="V1XVYtCe2MvbP4u2Uib0-18" parent="V1XVYtCe2MvbP4u2Uib0-17" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;3 types of vehicle (small, medium, large)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;parking slot sizes (small, medium, large)&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;parking lot -&amp;gt; assign slot as per availability and assign ticket on checkin&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;parking lot -&amp;gt; on check-out calculate fair&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;fair strategy -&amp;gt; regular fair, peak hours fair&lt;/li&gt;&lt;/ul&gt;" vertex="1">

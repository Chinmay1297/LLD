        </mxCell>
        <mxCell id="V1XVYtCe2MvbP4u2Uib0-19" parent="V1XVYtCe2MvbP4u2Uib0-17" style="text;html=1;whiteSpace=wrap;strokeColor=#B09500;fillColor=#e3c800;align=center;verticalAlign=middle;rounded=0;fontColor=#000000;" value="&lt;ul&gt;&lt;li style=&quot;text-align: left;&quot;&gt;Vehicle comes to parking lot -&amp;gt; it checks if slot is available, then assign slot, else reject, if slot is assigned -&amp;gt; assign ticket on entry -&amp;gt; and then on check out calculate fair. Fair is calculated based on parking slot size and hours parked.&lt;/li&gt;&lt;/ul&gt;" vertex="1">
